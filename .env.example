# DriftIQ — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=driftiq
POSTGRES_USER=driftiq
POSTGRES_PASSWORD=change-me-strong-password-here
POSTGRES_PORT=5432

# ── Database (used by app) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://driftiq:change-me-strong-password-here@localhost:5432/driftiq

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT Keys ───────────────────────────────────────────────────
# Generate with:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=RS256

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-min-32-chars-required
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
API_PORT=8000
NGINX_PORT=80

# ── LLM ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_FALLBACK_ENABLED=true
LLM_TIMEOUT_SECONDS=30

# ── Firebase (push notifications) ──────────────────────────────
FIREBASE_CREDENTIALS_PATH=./keys/firebase-service-account.json
FIREBASE_ENABLED=false

# ── AWS S3 (data exports) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=driftiq-exports
AWS_REGION=us-east-1

# ── Nightly Compute Schedule (UTC) ─────────────────────────────
NIGHTLY_COMPUTE_HOUR=2
NIGHTLY_COMPUTE_MINUTE=0

# ── Drift Thresholds ───────────────────────────────────────────
DRIFT_ALERT_THRESHOLD=40.0
DRIFT_DIMENSION_SPIKE_Z=2.5
DRIFT_SUSTAINED_THRESHOLD=25.0

# ── Data Retention ─────────────────────────────────────────────
DEFAULT_DATA_RETENTION_DAYS=365

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Sentry (optional) ──────────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project
