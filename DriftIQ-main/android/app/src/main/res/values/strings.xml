    <string name="permission_usage_title">App Usage Access</string>
    <string name="permission_usage_body">DriftIQ needs access to your app usage data to track behavioral patterns. This is the core of your Behavioral Digital Twin. No app content is ever accessed — only which apps you used and for how long.</string>
